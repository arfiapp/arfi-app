# Circle Console → App Kit Key (format: KIT_KEY:id:secret)
NEXT_PUBLIC_KIT_KEY=KIT_KEY:your_id:your_secret
# Opsiyonel: sunucu tarafli proxy icin (NEXT_PUBLIC ile ayni deger olabilir)
KIT_KEY=KIT_KEY:your_id:your_secret

# Arc Testnet (resmi — docs.arc.io). ESKI rpc.arc.network KULLANMAYIN.
NEXT_PUBLIC_ARC_RPC=https://rpc.testnet.arc.network
NEXT_PUBLIC_CHAIN_ID=5042002
# Bos birakirsaniz otomatik fallback RPC listesi kullanilir

# WalletConnect — cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
